{
  "expo": {
    "name": "PitStop Mobile",
    "slug": "pitstop-mobile",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#03030A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pitstop.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#03030A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pitstop.mobile"
    },
    "scheme": "pitstopmobile",
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
